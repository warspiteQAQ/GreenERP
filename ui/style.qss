QMainWindow {
    background-color: #f4f6f9;
}

#sidebar {
    background-color: #1f2d3d;
}

QPushButton {
    background-color: #2e3e4e;
    color: white;
    border-radius: 6px;
}

QPushButton:hover {
    background-color: #3c8dbc;
}

#sidebarToggle {
    background-color: #1b2633;
    border-radius: 14px;
    padding: 0;
    font-weight: bold;
}

#sidebarToggle:hover {
    background-color: #4b5b6d;
}

QLabel {
    color: #333;
}
